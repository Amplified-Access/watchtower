# Environment
APP_ENV=development
ENV=development
LOG_LEVEL=info

# Server
PORT=8080

# Database
DATABASE_URL=postgresql://user:password@host/dbname

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (for password reset links, etc.)
FRONTEND_URL=http://localhost:3000

# Cookie domain (use .yourdomain.com for production to share cookies across subdomains)
COOKIE_DOMAIN=

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me

# OAuth (Google — from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (file storage)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_KEY=
CLOUDFLARE_S3_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=

# Email (Mailjet SMTP)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Internal service secret (shared with frontend for email endpoint auth)
INTERNAL_EMAIL_SECRET=

# Location search (LocationIQ)
LOCATION_IQ_API_KEY=

# AWS SNS (alert notifications)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_TOPIC_ARN=

# AI (Google Generative AI)
GOOGLE_GENERATIVE_AI_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Sentry (error monitoring)
SENTRY_DSN=