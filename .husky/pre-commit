#!/bin/sh

echo "Running pre-commit checks..."

echo ""
echo "Frontend: lint"
(cd frontend && pnpm lint) || exit 1

echo ""
echo "Frontend: tests"
(cd frontend && pnpm exec jest --passWithNoTests) || exit 1

echo ""
echo "Frontend: build"
(cd frontend && pnpm build) || exit 1

echo ""
echo "Backend: vet"
(cd backend && go vet ./...) || exit 1

echo ""
echo "Backend: tests (unit only — integration tests run in CI)"
(cd backend && { _pkgs=$(go list ./... | grep -v 'internal/database' | grep -v 'pkg/postgres'); [ -z "$_pkgs" ] || go test $_pkgs; }) || exit 1

echo ""
echo "Backend: build"
(cd backend && go build ./cmd/api/main.go) || exit 1

echo ""
echo "All pre-commit checks passed."
